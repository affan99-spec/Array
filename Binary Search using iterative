
#include <iostream>

using namespace std;

struct Array
{
    int A[10];
    int size;
    int Length;
};

int BinarySearch(struct Array arr,int key)
{
    int l, mid, h;
    l=0, h=arr.Length-1;
    mid = (l+h) / 2;
    while(l <= h)
    {
        if(key == arr.A[mid])
            return mid;
        else if(key < arr.A[mid])
            h = mid-1;
        else 
            l = mid+1;
    }
    return -1;
}

void Display(struct Array arr)
{
    int i;
    cout<<"Elements are: \n";
    for(i=0; i<arr.Length; i++) 
    {
        cout<<arr.A[i]<<" ";
    }
}

int main()
{
    struct Array arr={{2,3,4,5,6,10,8,9},1,7};
    int value = BinarySearch(arr,5);
    cout<<"The index found is: "<<value<<endl;
    Display(arr);

    return 0;
}
