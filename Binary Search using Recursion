
#include <iostream>

using namespace std;

struct Array 
{
    int A[10];
    int size;
    int Length;
};

int RBinSearch(int a[],int l,int h, int key)
{
    int mid;
    mid = (l+h)/2;
    if(l <= h)
    {
        if(key == a[mid])
            return mid;
        else if(key < a[mid])
            return RBinSearch(a, l, mid-1, key);
        else 
            return RBinSearch(a, mid+1, h, key);
    }
    return -1;
}

void Display(struct Array arr)
{
    int i;
    cout<<"Elements are: \n";
    for(i=0; i<arr.Length; i++)
    {
        cout<<arr.A[i]<<" ";
    }
}

int main()
{
    struct Array arr={{2,3,4,5,6,7},8,9};
    int value = RBinSearch(arr.A, 0, arr.Length, 2);
    cout<<"The Element Found at index is: "<<value<<endl;
    Display(arr);

    return 0;
}
