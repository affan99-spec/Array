#include <bits/stdc++.h>
#include <stdio.h>
#include <stdlib.h>
using namespace std;

int main() {
    
	int A[5]={2,4,6,8,10};
	int *p;
	p=new int[5];
	p[0]=3;
	p[1]=5;
	p[2]=7;
	p[3]=9;
	p[4]=11;
	int i;
	
	for(i=0; i<5; i++) {
	    printf("%d ", A[i]); // store in stack memory.
	}
	cout<<endl;
	
	for(i=0; i<5; i++) {
	    cout<<p[i]<<" ";  // store in dynamic memory or heap memory.
	}
	return 0;
}
