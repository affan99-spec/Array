#include <iostream>

using namespace std;


int main()
{
    int *p, *q;
    int i;
    p=new int[5]; // create size of array in heap memory is 5.
    p[0]=3; p[1]=5; p[2]=7; p[3]=9; p[4]=11;
    
    q = new int[10]; // create size of array in heap memory is 10.
    for(i=0; i<5; i++) 
        q[i] = p[i]; // value of p is assign to q.
    delete []p;  // delete the array of p in heap memory. 
    p=q;      // assign q pointer array to p.
    q=NULL;
    for(i=0; i<5; i++) {
        cout<<p[i]<<endl;
    }
    return 0;
}
